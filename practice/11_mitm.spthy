// Edge server__23/event_let_exit_s__190 : rho__127 <- (); drop req__17; drop dh_c__18; drop y__19; drop session_key_s__20
rule event_let_exit_s__190[role="server__23"]
  : [ State_server__23_0_2_0_6(%v, rho__127, session_key_s__20, y__19, dh_c__18, req__17) ]
    --[ Secret(session_key_s__20),

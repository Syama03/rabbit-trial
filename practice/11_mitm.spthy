// Edge server__23/send_app_in_put___183 : rho__117 <- ()
rule send_app_in_put___183[role="server__23"]
  : [ !ACP('server__23', 'chan:net', 'send'),
      State_server__23_0_2_0_3(%v, rho__117, session_key_s__20, y__19, dh_c__18, req__17) ]
    --[ Transition('server__23', 'index:0.2_0.3', %v) ]->

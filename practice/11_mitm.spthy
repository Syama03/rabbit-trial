theory rabbit
begin
builtins: natural-numbers, diffie-hellman

//// Signature


//// Constants


//// Proc group initialization

// Proc group initialization PG_client__22
rule Init_PG_client__22[role="PG_client__22"]
  : [  ]
    --[ Init(<'Proc_group', 'PG_client__22'>) ]->
    [ !Inited_proc_group('PG_client__22'),
      State_client__21_0_0(%1, '()') ]

// Proc group initialization PG_server__24
rule Init_PG_server__24[role="PG_server__24"]
  : [  ]
    --[ Init(<'Proc_group', 'PG_server__24'>) ]->
    [ !Inited_proc_group('PG_server__24'),
      State_server__23_0_0(%1, '()') ]


//// Access control

// Access control for proc client__21 of group PG_client__22
rule Access_client__21[role="client__21"]
  : [ !Inited_proc_group('PG_client__22') ]
    --[ Init(<'Proc_access', 'client__21'>) ]->
    [ !ACP('client__21', 'chan:net', 'send'),
      !ACP('client__21', 'chan:net', 'recv') ]

// Access control for proc server__23 of group PG_server__24
rule Access_server__23[role="server__23"]
  : [ !Inited_proc_group('PG_server__24') ]
    --[ Init(<'Proc_access', 'server__23'>) ]->
    [ !ACP('server__23', 'chan:net', 'send'),
      !ACP('server__23', 'chan:net', 'recv') ]

//// Proc models

// Model of proc client__21

// Attack edge client__21/new_intro_eaves___144 : rho__25 <- (); new x__12
rule new_intro_eaves___144[role="client__21"]
  : [ !ACP('client__21', 'chan:net', 'send'),
      Fr(x__12),
      State_client__21_0_0(%v, rho__25) ]
    --[ Transition('client__21', 'index:0.0', %v) ]->
    [ Out(<'str:INIT', 'g'^x__12>),
      State_client__21_0_3(%v, '()', x__12),
      Store('chan:net', <'str:INIT', 'g'^x__12>) ]

// Edge client__21/recv_app_in__52 : rho__51 <- (); new c__4 = net
rule recv_app_in__52[role="client__21"]
